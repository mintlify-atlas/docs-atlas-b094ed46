  "keyFeatures": [
    "Text-to-speech generation with adjustable creativity, variety, expression, and flow parameters",
    "Zero-shot voice cloning from audio samples (10s minimum) - no fine-tuning required",
    "20 built-in voices across 12 categories (audiobook, conversational, meditation, etc.)",
    "Multi-tenant architecture with Clerk Organizations for team-based access",
    "Usage-based billing with character metering via Polar",
    "Generation history with preserved voice metadata and waveform visualization",
    "Waveform audio player with WaveSurfer.js integration",
    "Cloudflare R2 storage for audio files"
  ],
  "publicApiSurface": [
    "voices.getAll({ query?: string })",
    "voices.delete({ id: string })",
    "generations.create({ text, voiceId, temperature?, topP?, topK?, repetitionPenalty? })",
    "generations.getAll()",
    "generations.getById({ id: string })",
    "billing.getStatus()",
    "billing.createCheckout()",
    "billing.createPortalSession()",
    "POST /api/audio/{generationId}",
    "POST /api/voices/upload",
    "Chatterbox TTS API: POST /generate"
  ]
